      <component id="657d9" class="javax.swing.JLabel" binding="o2ValueLabel">
        <constraints>
          <grid row="4" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
