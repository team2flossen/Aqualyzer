<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.aqualyzer.ui.MessungEditor">
  <grid id="27dc6" binding="contentPane" layout-manager="GridBagLayout">
    <constraints>
      <xy x="10" y="15" width="500" height="256"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="4d6f7" class="javax.swing.JSpinner" binding="dateTimeSpinner" custom-create="true">
        <constraints>
          <grid row="1" column="2" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="1.0" weighty="0.0"/>
        </constraints>
        <properties/>
      </component>
      <component id="1f6a7" class="javax.swing.JLabel">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
          <text value="Zeitstempel"/>
        </properties>
      </component>
      <component id="36e7f" class="javax.swing.JLabel" binding="stationLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
          <text value="Station"/>
        </properties>
      </component>
      <hspacer id="27630">
        <constraints>
          <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
          <gridbag weightx="1.0" weighty="0.0"/>
        </constraints>
      </hspacer>
      <component id="3e00" class="javax.swing.JLabel">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
          <text value="pH-Wert"/>
        </properties>
      </component>
      <component id="bc50c" class="javax.swing.JLabel">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
          <text value="Wassertemperatur (°C)"/>
        </properties>
      </component>
      <component id="95c95" class="javax.swing.JLabel">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
          <text value="Sauerstoffgehalt  (mg/L)"/>
        </properties>
      </component>
      <component id="ca709" class="javax.swing.JLabel">
        <constraints>
          <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
          <text value="Salzgehalt (PSU)"/>
        </properties>
      </component>
      <component id="25bd7" class="javax.swing.JButton" binding="okButton">
        <constraints>
          <grid row="6" column="2" row-span="1" col-span="2" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="3.0" weighty="0.0"/>
        </constraints>
        <properties>
          <icon value="icons/accept.png"/>
          <text value="Bestätigen"/>
        </properties>
      </component>
      <component id="d6934" class="javax.swing.JButton" binding="cancelButton">
        <constraints>
          <grid row="6" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="1.0" weighty="0.0"/>
        </constraints>
        <properties>
          <icon value="icons/cancel.png"/>
          <text value="Abbrechen"/>
        </properties>
      </component>
      <component id="6ee89" class="javax.swing.JTextField" binding="stationField">
        <constraints>
          <grid row="0" column="2" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
            <preferred-size width="150" height="-1"/>
          </grid>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties/>
      </component>
      <component id="7b0ec" class="javax.swing.JSlider" binding="phSlider">
        <constraints>
          <grid row="2" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
          <maximum value="14"/>
          <value value="7"/>
        </properties>
      </component>
      <component id="e042d" class="javax.swing.JSlider" binding="temperatureSlider">
        <constraints>
          <grid row="3" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
          <minimum value="-40"/>
          <value value="20"/>
        </properties>
      </component>
      <component id="84be1" class="javax.swing.JSlider" binding="o2Slider">
        <constraints>
          <grid row="4" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
          <gridbag top="5" left="5" bottom="5" right="5" weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties>
